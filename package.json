{
  "name": "@koppajs/koppajs-language-core",
  "version": "0.1.3",
  "description": "Shared KoppaJS language primitives, semantic service, and workspace graph.",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=16"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/koppajs/koppajs-language-core.git"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run validate",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "validate": "npm run check:docs && npm run typecheck && npm run test && npm run build",
    "check:docs": "node scripts/check-doc-contract.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "vitest": "^3.2.4",
    "husky": "^9.1.7"
  },
  "publishConfig": {
    "access": "public"
  },
  "private": false
}
